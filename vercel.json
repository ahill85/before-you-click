{
  "redirects": [
    {
      "source": "/",
      "missing": [{ "type": "header", "key": "x-astar-proxy" }],
      "destination": "https://astarmedia.net/before-you-click/",
      "permanent": true
    },
    {
      "source": "/:path((?!api/).+)",
      "missing": [{ "type": "header", "key": "x-astar-proxy" }],
      "destination": "https://astarmedia.net/before-you-click/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
